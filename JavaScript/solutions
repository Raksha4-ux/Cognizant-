  { id: 6, name: "Yoga Retreat",          date: "2025-12-01", category: "sports",   seats: 30,  location: "Riverside" },
];

const today = new Date();

function isUpcoming(event) {
  return new Date(event.date) >= today;
}

function isAvailable(event) {
  return event.seats > 0;
}

function getValidEvents(events) {
  return events.filter(e => isUpcoming(e) && isAvailable(e));
}

function registerForEvent(event) {
  try {
    if (!isUpcoming(event)) throw new Error(`"${event.name}" is a past event.`);
    if (!isAvailable(event)) throw new Error(`"${event.name}" is fully booked.`);
    event.seats--;
    console.log(`Registered for "${event.name}". Seats left: ${event.seats}`);
  } catch (err) {
    console.error("Registration error:", err.message);
  }
}

// Loop through and log valid events
eventsData.forEach(event => {
  if (isUpcoming(event) && isAvailable(event)) {
    console.log(` ${event.name} — ${event.date}`);
  } else {
    console.log(` Skipped: ${event.name} (past or full)`);
  }
});


