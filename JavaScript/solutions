// Mock JSON endpoint (using JSONPlaceholder as a stand-in, we'll merge our own data)
const MOCK_API_URL = "https://jsonplaceholder.typicode.com/posts?_limit=3";

// Using .then() and .catch()
function fetchEventDataPromise() {
  document.querySelector("#loading").style.display = "block";
  fetch(MOCK_API_URL)
    .then(res => {
      if (!res.ok) throw new Error("Network response was not ok");
      return res.json();
    })
    .then(data => {
      console.log("Fetched mock data (promise):", data);
      document.querySelector("#loading").style.display = "none";
    })
    .catch(err => {
      console.error("Fetch error:", err);
      document.querySelector("#loading").style.display = "none";
    });
}

// Using async/await
async function fetchEventDataAsync() {
  document.querySelector("#loading").style.display = "block";
  try {
    const res = await fetch(MOCK_API_URL);
    if (!res.ok) throw new Error("Network response was not ok");
    const data = await res.json();
    console.log("Fetched mock data (async/await):", data);
  } catch (err) {
    console.error("Async fetch error:", err);
  } finally {
    document.querySelector("#loading").style.display = "none";
  }
}


