  document.querySelector("#err-email").textContent = "";
  document.querySelector("#err-event").textContent = "";
  document.querySelector("#form-message").textContent = "";

  let valid = true;

  if (!name) {
    document.querySelector("#err-name").textContent = "Name is required.";
    valid = false;
  }
  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    document.querySelector("#err-email").textContent = "Valid email is required.";
    valid = false;
  }
  if (!eventId) {
    document.querySelector("#err-event").textContent = "Please select an event.";
    valid = false;
  }

  if (!valid) return;

  // Simulate async POST (Module 12)
  submitRegistration({ name, email, eventId });
});
