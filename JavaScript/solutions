// ============================================================
// MODULE 7: DOM Manipulation
// ============================================================

function renderEvents(events) {
  const container = document.querySelector("#events-container");
  container.innerHTML = "";

  const validEvents = getValidEvents(events);

  if (validEvents.length === 0) {
    container.innerHTML = "<p>No events found.</p>";
    return;
  }

  validEvents.forEach(event => {
    const card = document.createElement("div");
    card.classList.add("event-card");
    card.dataset.id = event.id;

    card.innerHTML = `
      <h3>${event.name}</h3>
      <p>📅 ${event.date}</p>
      <p>📍 ${event.location}</p>
      <p>🏷️ ${event.category}</p>
      <p>💺 Seats: <span id="seats-${event.id}">${event.seats}</span></p>
      <button onclick="handleRegister(${event.id})">Register</button>
      <button onclick="handleCancel(${event.id})" style="background:#dc3545; margin-left:5px;">Cancel</button>
    `;

    // Populate the registration form dropdown too
    const regSelect = document.querySelector("#reg-event");
    const option = document.createElement("option");
    option.value = event.id;
    option.textContent = event.name;
    regSelect.appendChild(option);

    container.appendChild(card);
  });
}

// Update seat count in the UI
function updateSeatDisplay(eventId) {
  const event = eventsData.find(e => e.id === eventId);
  const seatEl = document.querySelector(`#seats-${eventId}`);
  if (seatEl && event) seatEl.textContent = event.seats;
}


// ============================================================
// MODULE 8: Event Handling
// ============================================================

// onclick for Register / Cancel buttons (defined globally for inline onclick)
function handleRegister(eventId) {
  const event = eventsData.find(e => e.id === eventId);
  if (!event) return;
  try {
    if (!isAvailable(event)) throw new Error("No seats left!");
    event.seats--;
    updateSeatDisplay(eventId);
    alert(`Registered for "${event.name}"!`);
  } catch (err) {
    alert(err.message);
  }
}

function handleCancel(eventId) {
  const event = eventsData.find(e => e.id === eventId);
  if (!event) return;
  event.seats++;
  updateSeatDisplay(eventId);
  alert(`Cancelled registration for "${event.name}". Seat freed.`);
}

// onchange: filter events by category
document.querySelector("#category-filter").onchange = function () {
  const selected = this.value;
  const filtered = selected === "all"
    ? eventsData
    : eventsData.filter(e => e.category === selected);
  renderEvents(filtered);
};

// keydown: quick search by name
document.querySelector("#search-input").addEventListener("keydown", function () {
  const query = this.value.toLowerCase();
  const filtered = eventsData.filter(e => e.name.toLowerCase().includes(query));
  renderEvents(filtered);
});


